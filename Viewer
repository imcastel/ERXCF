repeat task.wait() until _G.WindUI and (_G.Tabs or getgenv().Tabs)

local WindUI = getgenv().WindUI or _G.WindUI
local Tabs = getgenv().Tabs or _G.Tabs

-- Wait for the specific Visuals tab to be initialized by the main script
local startTime = tick()
while (not Tabs or not Tabs.Visuals) and tick() - startTime < 15 do
    task.wait(0.5)
    Tabs = getgenv().Tabs or _G.Tabs
end

if not Tabs or not Tabs.Visuals then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "ERX Viewer",
        Text = "Could not find Visuals tab. Load ERX first!",
        Duration = 8
    })
    return
end

-- Services
local Players = cloneref(game:GetService("Players"))
local RunService = cloneref(game:GetService("RunService"))
local LocalPlayer = Players.LocalPlayer
local Workspace = cloneref(game:GetService("Workspace"))

-- Logic Variables
local viewerEnabled = false
local viewConnection = nil
local currentTarget = nil

local function stopViewing()
    if viewConnection then
        viewConnection:Disconnect()
        viewConnection = nil
    end
    currentTarget = nil
    
    Workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    local char = LocalPlayer.Character
    if char and char:FindFirstChildWhichIsA("Humanoid") then
        Workspace.CurrentCamera.CameraSubject = char:FindFirstChildWhichIsA("Humanoid")
    end
end

local function startViewing(targetPlayer)
    stopViewing()
    currentTarget = targetPlayer
    
    viewConnection = RunService.RenderStepped:Connect(function()
        if not viewerEnabled or not currentTarget then return end
        
        local targetChar = currentTarget.Character
        if not targetChar then return end
        
        local targetHum = targetChar:FindFirstChildWhichIsA("Humanoid")
        if targetHum then
            Workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
            Workspace.CurrentCamera.CameraSubject = targetHum
        end
    end)
    
    WindUI:Notify({
        Title = "Viewer",
        Content = "Now viewing: " .. targetPlayer.Name,
        Duration = 4,
        Icon = "eye"
    })
end

-- Injecting into the Pre-existent Visuals Tab
local Visuals = Tabs.Visuals

Visuals:Section({ Title = "Player Viewer" })

Visuals:Toggle({
    Title = "Viewer Mode",
    Desc = "Must be ON to lock camera",
    Value = false,
    Callback = function(state)
        viewerEnabled = state
        if not state then stopViewing() end
    end
})

local nameInput = Visuals:Input({
    Title = "Player Name",
    Desc = "Search by username",
    Placeholder = "Enter name...",
    Value = "",
    Callback = function() end
})

Visuals:Button({
    Title = "Start Viewing",
    Desc = "Search and lock camera",
    Icon = "lucide:eye",
    Callback = function()
        if not viewerEnabled then
            WindUI:Notify({ Title = "Viewer", Content = "Turn on Viewer Mode first!", Duration = 3, Icon = "alert-triangle" })
            return
        end
        
        local searchText = nameInput.Value or ""
        local search = searchText:lower()
        local target = nil
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Name:lower():find(search) then
                target = plr
                break
            end
        end
        
        if target then
            startViewing(target)
        else
            WindUI:Notify({ Title = "Viewer", Content = "Player not found", Duration = 3, Icon = "x-circle" })
        end
    end
})

Visuals:Button({
    Title = "Stop Viewing",
    Desc = "Return camera to self",
    Icon = "lucide:eye-off",
    Callback = function()
        stopViewing()
        WindUI:Notify({ Title = "Viewer", Content = "Returned to character", Duration = 3, Icon = "eye-off" })
    end
})
