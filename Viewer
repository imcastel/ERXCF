    Callback = function()
        local path = "WindUI/CustomFeatures/CustomFeatures.lua"
        local line = '\nloadstring(game:HttpGet("https://raw.githubusercontent.com/imcastel/ERXCF/refs/heads/main/Viewer"))() -- Viewer for ERX\n'
