repeat task.wait() until _G.WindUI and _G.Tabs

local WindUI = getgenv().WindUI or _G.WindUI
local Tabs = getgenv().Tabs or _G.Tabs

-- Wait for ERX UI to fully load
local startTime = tick()
while (not Tabs or not Tabs.Main) and tick() - startTime < 15 do
    task.wait(0.5)
    Tabs = getgenv().Tabs or _G.Tabs
end

if not Tabs or not Tabs.Main then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "ERX Server Hop",
        Text = "Could not find ERX Main tab. Load ERX first!",
        Duration = 8
    })
    return
end

-- Server Hop Function (Strict >15 players)
local function ServerHop()
    local TeleportService = game:GetService("TeleportService")
    local HttpService = game:GetService("HttpService")
    local PlaceId = game.PlaceId
    
    
    pcall(function()
        local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        local validServers = {}
        
        for _, v in ipairs(servers.data) do
            if v.playing and v.maxPlayers and v.playing > 15 and v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(validServers, v)
            end
        end
        
        if #validServers > 0 then
            table.sort(validServers, function(a, b)
                return a.playing > b.playing
            end)
            
            local target = validServers[math.random(1, math.min(5, #validServers))]
            WindUI:Notify({
                Title = "Server Hop",
                Content = "Hopping... (" .. target.playing .. "/" .. target.maxPlayers .. " players)",
                Duration = 4
            })
            TeleportService:TeleportToPlaceInstance(PlaceId, target.id)
        else
            WindUI:Notify({
                Title = "Server Hop",
                Content = "No servers with 16+ players found. Retrying in 8s...",
                Duration = 5
            })
            task.wait(8)
            ServerHop()
        end
    end)
end

-- Add button to Main Tab
Tabs.Main:Section({ Title = "Server Utilities" })

Tabs.Main:Button({
    Title = "Server Hop",
    Callback = function()
        ServerHop()
    end,
})
