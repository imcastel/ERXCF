-- =============================================
-- ERX SERVER HOP - ONLY SERVERS WITH >15 PLAYERS
-- Execute AFTER loading ERX with Potassium
-- =============================================

repeat task.wait() until _G.WindUI and _G.Tabs

local WindUI = getgenv().WindUI or _G.WindUI
local Tabs = getgenv().Tabs or _G.Tabs

-- Wait for ERX UI to fully load
local startTime = tick()
while (not Tabs or not Tabs.Main) and tick() - startTime < 15 do
    task.wait(0.5)
    Tabs = getgenv().Tabs or _G.Tabs
end

if not Tabs or not Tabs.Main then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "ERX Server Hop",
        Text = "Could not find ERX Main tab. Load ERX first!",
        Duration = 8
    })
    return
end

-- Updated Server Hop Function - Only servers with more than 15 players
local function ServerHop()
    local TeleportService = game:GetService("TeleportService")
    local HttpService = game:GetService("HttpService")
    local PlaceId = game.PlaceId
    
    WindUI:Notify({
        Title = "Server Hop",
        Content = "Searching for servers with 16+ players...",
        Duration = 4
    })
    
    pcall(function()
        local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        local validServers = {}
        
        for _, v in ipairs(servers.data) do
            if v.playing > 15 and v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(validServers, v)
            end
        end
        
        if #validServers > 0 then
            local target = validServers[math.random(1, #validServers)]
            WindUI:Notify({
                Title = "Server Hop",
                Content = "Hopping to server with " .. target.playing .. " players...",
                Duration = 5
            })
            TeleportService:TeleportToPlaceInstance(PlaceId, target.id)
        else
            WindUI:Notify({
                Title = "Server Hop",
                Content = "No servers with 16+ players found.\nRetrying in 6 seconds...",
                Duration = 6
            })
            task.wait(6)
            ServerHop()  -- Retry
        end
    end)
end

-- Add button to Main Tab
Tabs.Main:Section({ Title = "Server Utilities" })

Tabs.Main:Button({
    Title = "Server Hop (>15 Players)",
    Desc = "Hops only to servers that have more than 15 players",
    Callback = function()
        ServerHop()
    end,
})

WindUI:Notify({
    Title = "Server Hop Updated",
    Content = "Server Hop button added to Main tab!\nNow only hops to servers with 16+ players.",
    Duration = 6
})
