-- Car Rainbow
local rainbowConnection = nil
local originalColors = {}

local rainbowToggle = ModsTab:Toggle({
	Title = "Car Rainbow",
	Desc = "Cycles your current vehicle's color rapidly",
	Value = false,
	Callback = function(state)
		if rainbowConnection then
			rainbowConnection:Disconnect()
			rainbowConnection = nil
		end
		
		if state then
			local vehicle = GetVehicle()
			if not vehicle then
				Notify("Rainbow", "Enter a vehicle first!", 3)
				return
			end
			
			if next(originalColors) == nil then
				for _, part in ipairs(vehicle:GetDescendants()) do
					if part:IsA("BasePart") and part.Name ~= "CollisionPart" then
						originalColors[part] = part.Color
					end
				end
			end
			
			rainbowConnection = RunService.Heartbeat:Connect(function()
				local currentVehicle = GetVehicle()
				if not currentVehicle then return end
				local hue = (tick() * 2) % 1
				local color = Color3.fromHSV(hue, 1, 1)
				for _, part in ipairs(currentVehicle:GetDescendants()) do
					if part:IsA("BasePart") and part.Name ~= "CollisionPart" then
						part.Color = color
					end
				end
			end)
		end
	end,
})
VCConfig:Register("rainbowToggle", rainbowToggle)

-- Reset Car Color
local resetColorButton = ModsTab:Button({
	Title = "Reset Car Color",
	Desc = "Restores the vehicle to its exact original colors",
	Locked = false,
	Callback = function()
		if rainbowConnection then
			rainbowConnection:Disconnect()
			rainbowConnection = nil
		end
		
		local vehicle = GetVehicle()
		if not vehicle then
			Notify("Reset Color", "Enter a vehicle first!", 3)
			return
		end
		
		for part, originalColor in pairs(originalColors) do
			if part and part.Parent and originalColor then
				part.Color = originalColor
			end
		end
		
		originalColors = {}
		
		TryRestartVehicleUI()
		Notify("Reset Color", "Vehicle restored to original colors", 4)
	end,
})

-- No Brakes
local noBrakesToggle = ModsTab:Toggle({
	Title = "No Brakes",
	Desc = "Completely disables braking on your current vehicle",
	Value = false,
	Callback = function(state)
		local vehicle = GetVehicle()
		if not vehicle then
			Notify("No Brakes", "Enter a vehicle first!", 3)
			return
		end
		local success, Drive = GetDrive(vehicle)
		if not success or not Drive then return end
		
		if state then
			if not Drive._originalBrakes then
				Drive._originalBrakes = {
					BrakeAccel = Drive.BrakeAccel,
					BrakeDecel = Drive.BrakeDecel,
					ABSThreshold = Drive.ABSThreshold,
				}
			end
			Drive.BrakeAccel = 0
			Drive.BrakeDecel = 0
			Drive.ABSThreshold = 999
		else
			if Drive._originalBrakes then
				Drive.BrakeAccel = Drive._originalBrakes.BrakeAccel
				Drive.BrakeDecel = Drive._originalBrakes.BrakeDecel
				Drive.ABSThreshold = Drive._originalBrakes.ABSThreshold
				Drive._originalBrakes = nil
			end
		end
		
		TryRestartVehicleUI()
		Notify("No Brakes", state and "Brakes disabled - good luck stopping!" or "Brakes restored", 4)
	end,
})
VCConfig:Register("noBrakesToggle", noBrakesToggle)

