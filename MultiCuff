    Desc        = "How close players must be. Default: 35",
    Placeholder = "35",
    Callback    = function(val)
        local n = tonumber(val)
        if n and n > 0 then
            cfg.auraRange = n
            WindUI:Notify({ Title = "MultiCuff ", Content = "Range set to " .. n .. " studs", Duration = 2 })
        end
    end,
})

MCTab:Input({
    Title       = "🔄 Retry Delay (ms)",
    Desc        = "Delay between retry attempts per player. Default: 150",
    Placeholder = "150",
    Callback    = function(val)
        local n = tonumber(val)
        if n and n >= 0 then
            cfg.retryDelay = n / 1000
            WindUI:Notify({ Title = "MultiCuff", Content = "Retry delay set to " .. n .. "ms", Duration = 2 })
        end
    end,
})

MCTab:Button({
    Title    = "⛓ Attach All Nearby",
    Desc     = "Weld all nearby players to you",
    Callback = function()
        if not isPoliceTeam(LocalPlayer) then
            WindUI:Notify({ Title = "MultiCuff", Content = "Must be on Police / Sheriff team!", Duration = 4 })
            return
        end
        weldAllNearby()
    end,
})

MCTab:Button({
    Title    = "🚔 Arrest All",
    Desc     = "Arrest all currently attached players",
    Callback = arrestAll,
})

MCTab:Section({ Title = "Auto-Weld Aura" })

MCTab:Toggle({
    Title    = "🔗 Auto-Weld Aura",
    Desc     = "Automatically attaches anyone who walks into range",
    Value    = false,
    Callback = function(state)
        cfg.autoCuffLoop = state
        if state then startAutoWeld() else stopAutoWeld() end
        WindUI:Notify({
            Title   = "MultiCuff",
            Content = state and "Auto-Weld ON" or "Auto-Weld OFF",
            Duration = 2,
        })
    end,
})

MCTab:Section({ Title = "Keybinds" })

MCTab:Toggle({
    Title    = "⌨️ Enable Keybinds",
    Desc     = "Toggle all keybinds on/off",
    Value    = true,
    Callback = function(state) cfg.keybindEnabled = state end,
})

MCTab:Keybind({
    Title    = "Attach All Keybind",
    Desc     = "Press to attach all nearby players",
    Value    = "H",
    Callback = function(key) cfg.keybind = Enum.KeyCode[key] end,
})

MCTab:Keybind({
    Title    = " Arrest All Keybind",
    Desc     = "Press to arrest all attached players",
    Value    = "K",
    Callback = function(key) cfg.arrestKeybind = Enum.KeyCode[key] end,
})

MCTab:Section({ Title = "Config" })

MCTab:Button({
    Title    = "💾 Save Config",
    Desc     = "Save your current settings",
