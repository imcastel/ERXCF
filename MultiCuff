        if MCConfig then
            MCConfig:Save()
            WindUI:Notify({ Title = "MultiCuff", Content = "Config saved!", Duration = 3 })
        else
            WindUI:Notify({ Title = "MultiCuff", Content = "Config manager unavailable.", Duration = 3 })
        end
    end,
})
