local function notify(msg)
    WindUI:Notify({ Title = "🔗 MultiCuff", Content = msg, Duration = 3 })
end

-- Manual config save/load via file since WindUI flags aren't set
local CONFIG_PATH = "ERX/MultiCuff_config.json"

local function saveConfig()
    pcall(function() if not isfolder("ERX") then makefolder("ERX") end end)
    local data = {
        auraRange    = cfg.auraRange,
        retryDelay   = math.floor(cfg.retryDelay * 1000),
        autoCuffLoop = cfg.autoCuffLoop,
    }
    local ok = pcall(writefile, CONFIG_PATH, game:GetService("HttpService"):JSONEncode(data))
    notify(ok and "Config saved!" or "Failed to save config.")
end

local function loadConfig()
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not ok or not raw or raw == "" then return end
    local ok2, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if not ok2 or type(data) ~= "table" then return end
    if type(data.auraRange)    == "number"  then cfg.auraRange    = data.auraRange
    elseif type(data.auraRange) == "string" then cfg.auraRange    = tonumber(data.auraRange) or cfg.auraRange end
    if type(data.retryDelay)   == "number"  then cfg.retryDelay   = data.retryDelay / 1000
    elseif type(data.retryDelay) == "string" then cfg.retryDelay  = (tonumber(data.retryDelay) or (cfg.retryDelay * 1000)) / 1000 end
    if type(data.autoCuffLoop) == "boolean" then cfg.autoCuffLoop = data.autoCuffLoop end
end

loadConfig()

-- Debounced notify: only fires after the user stops dragging for 0.4s
local sliderDebounce = {}
local function sliderNotify(key, msg)
    sliderDebounce[key] = (sliderDebounce[key] or 0) + 1
    local snapshot = sliderDebounce[key]
    task.delay(0.4, function()
        if sliderDebounce[key] == snapshot then
            notify(msg)
        end
    end)
end

