local function panic()
    panicActive      = true
    cfg.autoCuffLoop = false
    if activeCuffThread then task.cancel(activeCuffThread) activeCuffThread = nil end
    stopAutoWeld()
    unequipHandcuffs()
    table.clear(cuffedPlayers)
    sendWebhook("Panic", "N/A", 0)
    notify("🚨 Panic! MultiCuff stopped.")
    task.delay(2, function() panicActive = false end)
end

