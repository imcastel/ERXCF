-- ───────────────────────────────────────────────────
-- Helpers
-- ───────────────────────────────────────────────────
local function notify(msg)
    WindUI:Notify({ Title = "🔗 MultiCuff", Content = msg, Duration = 3 })
end

local function isPoliceTeam(p)
    local t = p.Team
    return t and (t.Name == "Police" or t.Name == "Sheriff")
end

local function isWanted(p)
    if not p or not p.Team then return false end
    if p.Team.Name == "Jail" then return false end
    if p:FindFirstChild("Is_Wanted") then return true end
    if Settings and Settings:FindFirstChild("ArrestCivs") and Settings.ArrestCivs.Value then
        return p.Team.Name == "Civilian"
    end
    return false
end

-- Returns how many wanted stars a player has (ERLC stores this as "Bounty_Level")
local function getWantedLevel(p)
    local tag = p:FindFirstChild("Bounty_Level")
    if tag then return math.clamp(math.floor(tonumber(tag.Value) or 0), 0, 5) end
    if p:FindFirstChild("Is_Wanted") then return 1 end
    return 0
end

local function starsString(level)
    if level <= 0 then return "No stars" end
    return string.rep("⭐", level)
end

-- Comprehensive dead check
local function isDead(p)
    local char = p.Character
    if not char then return true end
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return true end
    if hum.Health <= 0 then return true end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return true end
    -- Ragdoll / incapacitated value on character
    if char:FindFirstChild("Ragdoll") then return true end
    -- Dead if HRP is missing or anchored (ERLC sometimes anchors dead chars)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return true end
    if hrp.Anchored and hum.Health <= 0 then return true end
    return false
end

local function isAlreadyCuffed(p)
    return p:FindFirstChild("In_Handcuffs") ~= nil
end

local function distanceTo(p)
    local myHRP = getHRP()
    local tHRP  = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP or not tHRP then return math.huge end
    return (myHRP.Position - tHRP.Position).Magnitude
end

local function isValidTarget(p)
    if p == LocalPlayer then return false end
    if isPoliceTeam(p) then return false end
    if cuffedPlayers[p] then return false end
    if isDead(p) then return false end
    if isAlreadyCuffed(p) then return false end
    if not isWanted(p) then return false end
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

local function hasAnyWanted()
    for _, p in ipairs(Players:GetPlayers()) do
        if isValidTarget(p) then return true end
    end
    return false
end

local function getHandcuffs()
    local bp   = LocalPlayer:FindFirstChildOfClass("Backpack")
    local char = getChar()
    return (bp and bp:FindFirstChild("Handcuffs")) or (char and char:FindFirstChild("Handcuffs"))
end

local function ensureHandcuffsEquipped()
    local hc  = getHandcuffs()
    local hum = getHuman()
    if not hc or not hum then return false end
    if not getChar():FindFirstChild("Handcuffs") then
        hum:EquipTool(hc)
        task.wait(0.1)
        pcall(function() EquippedHC:FireServer(true) end)
    end
    return true
end

local function unequipHandcuffs()
    local hum = getHuman()
    if hum then hum:UnequipTools() end
end

