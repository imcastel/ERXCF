-- Aura Visualizer
-- ───────────────────────────────────────────────────
local function buildAuraCircle()
    if auraCircle then auraCircle:Destroy() end

    -- Draw circle as a flat transparent cylinder
    local part = Instance.new("Part")
    part.Name        = "MultiCuffAura"
    part.Anchored    = true
    part.CanCollide  = false
    part.CanTouch    = false
    part.CastShadow  = false
    part.Material    = Enum.Material.Neon
    part.Color       = Color3.fromRGB(132, 32, 37)
    part.Transparency = 0.6
    part.Shape       = Enum.PartType.Cylinder
    local r = tonumber(cfg.auraRange) or 35
    part.Size        = Vector3.new(0.15, r * 2, r * 2)
    part.Parent      = workspace

    auraCircle = part
end

local function startAuraVisualizer()
    buildAuraCircle()
    if auraConn then auraConn:Disconnect() end
    auraConn = RunService.RenderStepped:Connect(function()
        local hrp = getHRP()
        if hrp and auraCircle then
            local r = tonumber(cfg.auraRange) or 35
            auraCircle.Size = Vector3.new(0.15, r * 2, r * 2)
            auraCircle.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y - 3, hrp.Position.Z)
                              * CFrame.Angles(0, 0, math.pi / 2)
        end
    end)
end

local function stopAuraVisualizer()
    if auraConn then auraConn:Disconnect() auraConn = nil end
    if auraCircle then auraCircle:Destroy() auraCircle = nil end
end


-- ───────────────────────────────────────────────────
-- Auto-refresh handcuffs (built-in, always runs)
-- Watches for handcuffs being unequipped or missing
-- and quietly re-equips them so they're always ready
-- ───────────────────────────────────────────────────
local function startHandcuffRefresh()
    if refreshConn then return end
    refreshConn = RunService.Heartbeat:Connect(function()
        if not cfg.autoCuffLoop then return end
        local char = getChar()
        if not char then return end
        -- Only refresh if not already holding cuffs and cuffs exist in backpack
        local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
        if bp and bp:FindFirstChild("Handcuffs") and not char:FindFirstChild("Handcuffs") then
            local hum = getHuman()
            if hum then
                hum:EquipTool(bp:FindFirstChild("Handcuffs"))
            end
        end
    end)
end

local function stopHandcuffRefresh()
    if refreshConn then refreshConn:Disconnect() refreshConn = nil end
end

