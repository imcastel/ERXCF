local function sendWebhook(event, targetName)
    if not cfg.webhookEnabled or cfg.webhookURL == "" then return end
    task.spawn(function()
        pcall(function()
            local payload = HttpService:JSONEncode({
                embeds = {{
                    title       = "MultiCuff — " .. event,
                    description = "**Officer:** " .. LocalPlayer.Name .. "\n**Target:** " .. targetName .. "\n**Server:** " .. game.JobId,
                    color       = event == "Arrest" and 15158332 or 3447003,
                    timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                }}
            })
            request({
                Url     = cfg.webhookURL,
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = payload,
            })
        end)
    end)
end

