-- ───────────────────────────────────────────────────
local function hookDeath(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    hum.Died:Connect(function()
        if not cfg.autoDisableOnDeath then return end
        cfg.autoCuffLoop = false
        stopAutoWeld()
        table.clear(cuffedPlayers)
        notify("Died — MultiCuff disabled.")
    end)
end

