-- Aura Visualizer (#842025)
-- ───────────────────────────────────────────────────
local function buildAuraCircle()
    if auraCircle then auraCircle:Destroy() end
    local r    = tonumber(cfg.auraRange) or 35
    local part = Instance.new("Part")
    part.Name         = "MultiCuffAura"
    part.Anchored     = true
    part.CanCollide   = false
    part.CanTouch     = false
    part.CastShadow   = false
    part.Material     = Enum.Material.Neon
    part.Color        = Color3.fromHex("842025")
    part.Transparency = 0.5
    part.Shape        = Enum.PartType.Cylinder
    part.Size         = Vector3.new(0.15, r * 2, r * 2)
    part.Parent       = workspace
    auraCircle = part
end

local function startAuraVisualizer()
    buildAuraCircle()
    if auraConn then auraConn:Disconnect() end
    auraConn = RunService.RenderStepped:Connect(function()
        local hrp = getHRP()
        if hrp and auraCircle then
            local r = tonumber(cfg.auraRange) or 35
            auraCircle.Size   = Vector3.new(0.15, r * 2, r * 2)
            auraCircle.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y - 3, hrp.Position.Z)
                              * CFrame.Angles(0, 0, math.pi / 2)
        end
    end)
end

local function stopAuraVisualizer()
    if auraConn   then auraConn:Disconnect()    auraConn   = nil end
    if auraCircle then auraCircle:Destroy()     auraCircle = nil end
end

