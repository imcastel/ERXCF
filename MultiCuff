-- ───────────────────────────────────────────────────
-- Input
-- ───────────────────────────────────────────────────
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == cfg.panicKeybind then
        panic()
        return
    end
    if not cfg.autoCuffLoop then return end
    if input.KeyCode == cfg.keybind then
        if not isPoliceTeam(LocalPlayer) then notify("Must be on Police / Sheriff!") return end
        weldAllNearby()
    elseif input.KeyCode == cfg.arrestKeybind then
        arrestAll()
    end
end)

-- ───────────────────────────────────────────────────
-- Start
-- ───────────────────────────────────────────────────
startAutoWeld()
startTeamWatch()

notify("<b>MultiCuff Loaded!</b>\n\nH = Cuff | K = Arrest | F8 = Panic")
