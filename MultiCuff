MCTab:Keybind({ Title = "🚨 Panic Button", Desc = "Stops everything instantly (default: F8)", Value = "F8",
    Callback = function(key) cfg.panicKeybind = Enum.KeyCode[key] end })

-- ── Actions ──
MCTab:Section({ Title = "Actions" })

MCTab:Button({
    Title = "⛓ Cuff All Nearby",
    Callback = function()
        if not isPoliceTeam(LocalPlayer) then notify("Must be on Police / Sheriff team!") return end
        weldAllNearby()
    end,
})

MCTab:Button({ Title = "🚔 Arrest All", Callback = arrestAll })

MCTab:Button({
    Title    = "🚨 Panic",
    Desc     = "Stop everything immediately",
    Callback = panic,
})

