-- Discord Webhook — arrests and panic only
-- Saved as single URL, visually rich embeds
-- ───────────────────────────────────────────────────
local function sendWebhook(event, targetName, wantedLevel)
    if not cfg.webhookEnabled or cfg.webhookURL == "" then return end
    task.spawn(function()
        pcall(function()
            local isPanic  = event == "Panic"
            local isArrest = event == "Arrest"

            -- Color: arrest = gold, panic = red
            local color = isPanic and 15158332 or 16766720

            local title, desc
            if isPanic then
                title = "🚨  PANIC ACTIVATED"
                desc  =
                    ">>> 👮  **Officer**\n" .. LocalPlayer.Name .. "\n\n" ..
                    "⏱️  **Time**\n" .. os.date("%H:%M:%S")
            else
                local stars = starsString(wantedLevel or 0)
                title = "🚔  ARREST LOGGED"
                desc  =
                    ">>> 👮  **Officer**\n" .. LocalPlayer.Name .. "\n\n" ..
                    "🎯  **Target**\n" .. targetName .. "\n\n" ..
                    "⭐  **Wanted Level**\n" .. stars .. "\n\n" ..
                    "⏱️  **Time**\n" .. os.date("%H:%M:%S")
            end

            local payload = HttpService:JSONEncode({
                embeds = {{
                    title     = title,
                    description = desc,
                    color     = color,
                    footer    = { text = "MultiCuff for ERX  •  by castel0v2" },
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                }}
            })

            request({
                Url     = cfg.webhookURL,
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = payload,
            })
        end)
    end)
end

