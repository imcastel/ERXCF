local function checkCivilianSafety()
    local hum = getHuman()
    if not hum then return end
    if LocalPlayer:FindFirstChild("In_Handcuffs") then
        for target in pairs(cuffedPlayers) do
            if not isWanted(target) then
                notify("⚠️ Cuffed innocent — respawning!")
                hum:ChangeState(Enum.HumanoidStateType.Dead)
                cuffedPlayers[target] = nil
                return
            end
        end
    end
end

