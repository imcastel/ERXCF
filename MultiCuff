-- ───────────────────────────────────────────────────
-- Panic
-- ───────────────────────────────────────────────────
local function panic()
    panicActive      = true
    cfg.autoCuffLoop = false

    if activeCuffThread then task.cancel(activeCuffThread) activeCuffThread = nil end
    if autoCuffConn then autoCuffConn:Disconnect() autoCuffConn = nil end

    unequipHandcuffs()
    table.clear(cuffedPlayers)
    notify("🚨 Panic! MultiCuff stopped.")
    task.delay(2, function() panicActive = false end)
end

-- ───────────────────────────────────────────────────
-- Core weld
-- ───────────────────────────────────────────────────
local function weldPlayer(target)
    if panicActive then return false, "Panic active" end
    if not isValidTarget(target) then return false, "Invalid target" end
    if not ensureHandcuffsEquipped() then return false, "No handcuffs" end

    local myChar = getChar()
    if not myChar then return false, "No character" end

    local myHRP = getHRP()
    if myHRP then
        myHRP.AssemblyLinearVelocity  = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero
    end

    local tHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if tHRP then
        myChar:PivotTo(CFrame.new(tHRP.Position + Vector3.new(3.5, 2.5, 0)))
    end

    task.wait(0.08)

    for i = 1, cfg.maxAttempts do
        if panicActive then return false, "Panic active" end
        ensureHandcuffsEquipped()
        if isDead(target) then return false, "Target died" end
        if isAlreadyCuffed(target) then return false, "Already cuffed" end

        local Response = UseHandcuffs:InvokeServer("Handcuff", target)

            if cfg.autoArrest then
                task.wait(0.15)
                pcall(function() UseHandcuffs:InvokeServer("Arrest", target) end)
                cuffedPlayers[target] = nil
                sendWebhook("Arrest", target.Name)
                if cfg.playerHighlight then removeHighlight(target) 
                end


            return true, "Success"
        end

        local tHum = target.Character and target.Character:FindFirstChildWhichIsA("Humanoid")
        if tHum and tHum.SeatPart then task.wait(1.2) else task.wait(cfg.retryDelay) end
    end

    return false, "Max attempts reached"
end

-- ───────────────────────────────────────────────────
-- Arrest all
-- ───────────────────────────────────────────────────
local function arrestAll()
    local count = 0
    for target in pairs(cuffedPlayers) do
        pcall(function() UseHandcuffs:InvokeServer("Arrest", target) end)
        sendWebhook("Arrest", target.Name)
        if cfg.playerHighlight then removeHighlight(target) end
        cuffedPlayers[target] = nil
        count += 1
    end
    WindUI:Notify({
        Title   = "MultiCuff",
        Content = count > 0 and "Arrested " .. count .. " player(s)." or "Nobody cuffed.",
        Duration = 3,
    })
end

-- ───────────────────────────────────────────────────
-- Weld all nearby
-- ───────────────────────────────────────────────────
local function weldAllNearby()
    if activeCuffThread then task.cancel(activeCuffThread) activeCuffThread = nil end
    activeCuffThread = task.spawn(function()
        local targets = {}
        local range   = tonumber(cfg.auraRange) or 35
        for _, p in ipairs(Players:GetPlayers()) do
            if isValidTarget(p) and distanceTo(p) <= range then
                table.insert(targets, p)
            end
        end

        if #targets == 0 then
            WindUI:Notify({ Title = "MultiCuff", Content = "No valid targets nearby.", Duration = 3 })
            return
        end

        local threads = {}
        for _, target in ipairs(targets) do
            threads[#threads + 1] = task.spawn(function()
                local ok, msg = weldPlayer(target)
                if not ok then warn("[MultiCuff] Failed: " .. target.Name .. " — " .. msg) end
            end)
        end

        for _, t in ipairs(threads) do
            repeat task.wait() until coroutine.status(t) == "dead"
        end
        activeCuffThread = nil
    end)
end

-- ───────────────────────────────────────────────────
-- Server hop
-- ───────────────────────────────────────────────────
local function ServerHop()
    if hopInProgress then return end
    hopInProgress = true
    local TeleportService = game:GetService("TeleportService")
    local PlaceId = game.PlaceId
    WindUI:Notify({ Title = "Server Hop", Content = "Looking for populated server...", Duration = 3 })
    pcall(function()
        local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        local valid = {}
        for _, v in ipairs(servers.data) do
            if v.playing >= cfg.minServerPlayers and v.id ~= game.JobId then
                table.insert(valid, v)
            end
        end
        if #valid > 0 then
            local t = valid[math.random(1, #valid)]
            WindUI:Notify({ Title = "Server Hop", Content = "Hopping... (" .. t.playing .. " players)", Duration = 4 })
            TeleportService:TeleportToPlaceInstance(PlaceId, t.id)
        else
            WindUI:Notify({ Title = "Server Hop", Content = "No big servers found. Retrying...", Duration = 5 })
            task.wait(6)
            hopInProgress = false
            ServerHop()
        end
    end)
    task.delay(30, function() hopInProgress = false end)
end

-- ───────────────────────────────────────────────────
-- Auto-weld aura
-- ───────────────────────────────────────────────────
local function startAutoWeld()
    if autoCuffConn then return end
    autoCuffConn = RunService.Heartbeat:Connect(function()
        if not cfg.autoCuffLoop then return end

        if cfg.autoServerHop and not hopInProgress and not countdownActive then
            local now = tick()
            if now - lastHopCheck > 15 then
                lastHopCheck = now
                if not hasAnyWanted() then
                    countdownActive = true
                    task.spawn(function()
                        for i = 3, 1, -1 do
                            WindUI:Notify({ Title = "Server Hop", Content = "No wanted players. Hopping in " .. i .. "...", Duration = 1.2 })
                            task.wait(1)
                            if hasAnyWanted() then
                                WindUI:Notify({ Title = "Server Hop", Content = "Wanted player appeared. Cancelled.", Duration = 3 })
                                countdownActive = false
                                return
                            end
                        end
                        if not hasAnyWanted() then ServerHop()
                        else WindUI:Notify({ Title = "Server Hop", Content = "Wanted player appeared. Cancelled.", Duration = 3 }) end
                        countdownActive = false
                    end)
                end
            end
        end

        local range = tonumber(cfg.auraRange) or 35
        for _, p in ipairs(Players:GetPlayers()) do
            if isValidTarget(p) and distanceTo(p) <= range then
                task.spawn(weldPlayer, p)
            end
        end
    end)
end

local function stopAutoWeld()
    if autoCuffConn then autoCuffConn:Disconnect() autoCuffConn = nil end
end

-- ───────────────────────────────────────────────────
-- Auto disable on death
-- ───────────────────────────────────────────────────
local function hookDeath(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    hum.Died:Connect(function()
        if not cfg.autoDisableOnDeath then return end
        cfg.autoCuffLoop = false
        stopAutoWeld()
        table.clear(cuffedPlayers)
        notify("Died — MultiCuff disabled.")
    end)
end

if getChar() then task.spawn(hookDeath, getChar()) end
LocalPlayer.CharacterAdded:Connect(function(char) task.spawn(hookDeath, char) end)

