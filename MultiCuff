-- Notifications
-- ───────────────────────────────────────────────────
local pendingAttached = {}

local function flushAttachNotification()
    if notifyPending then return end
    notifyPending = true
    task.delay(0.5, function()
        if #pendingAttached > 0 then
            WindUI:Notify({
                Title   = "MultiCuff",
                Content = "⛓ Cuffed: " .. table.concat(pendingAttached, ", "),
                Duration = 3,
            })
            table.clear(pendingAttached)
        end
        notifyPending = false
    end)
end

-- ───────────────────────────────────────────────────
-- Core weld — vehicle ejection handled natively by
-- the Handcuff invoke itself (game auto-unsits after ~1s)
-- ───────────────────────────────────────────────────
local function weldPlayer(target)
    if panicActive then return false, "Panic active" end
    if not isValidTarget(target) then return false, "Invalid target" end
    if not ensureHandcuffsEquipped() then return false, "No handcuffs" end

    local myChar = getChar()
    if not myChar then return false, "No character" end

    local myHRP = getHRP()
    if myHRP then
        myHRP.AssemblyLinearVelocity  = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero
    end

    local tHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if tHRP then
        myChar:PivotTo(CFrame.new(tHRP.Position + Vector3.new(3.5, 2.5, 0)))
    end

    task.wait(0.08)

    for i = 1, cfg.maxAttempts do
        if panicActive then return false, "Panic active" end
        ensureHandcuffsEquipped()
        if isDead(target) then return false, "Target died" end
        if isAlreadyCuffed(target) then return false, "Already cuffed" end

        local Response = UseHandcuffs:InvokeServer("Handcuff", target)

        if Response == "Success" then
            cuffedPlayers[target] = true
            table.insert(pendingAttached, target.Name)
            flushAttachNotification()

            if cfg.autoArrest then
                task.wait(0.15)
                pcall(function() UseHandcuffs:InvokeServer("Arrest", target) end)
                sendWebhook("Arrest", target.Name, getWantedLevel(target))
                cuffedPlayers[target] = nil
            end

            return true, "Success"
        end

        -- If seated: game auto-unsits after invoke, wait for it then retry
        local tHum = target.Character and target.Character:FindFirstChildWhichIsA("Humanoid")
        if tHum and tHum.SeatPart then
            -- Wait until SeatPart clears (up to 1.5s) for smooth instant eject
            local t0 = tick()
            repeat task.wait(0.05) until not (tHum and tHum.SeatPart) or tick() - t0 > 1.5
        else
            task.wait(cfg.retryDelay)
        end
    end

    return false, "Max attempts reached"
end

