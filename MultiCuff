    Title    = "📌 Add to Custom Features",
    Desc     = "Loads MultiCuff every time ERX starts",
    Callback = function()
        local path = "WindUI/CustomFeatures/CustomFeatures.lua"
        local line = '\nloadstring(game:HttpGet("https://raw.githubusercontent.com/imcastel/ERXCF/refs/heads/main/MultiCuff"))() --MultiCuff\n'
        pcall(appendfile, path, line)
        WindUI:Notify({
            Title   = "MultiCuff",
            Content = "Added to custom features!",
            Duration = 8,
        })
    end,
})

UIS.InputBegan:Connect(function(input, processed)
    if processed or not cfg.keybindEnabled then return end
    if input.KeyCode == cfg.keybind then
        if not isPoliceTeam(LocalPlayer) then
            WindUI:Notify({ Title = "MultiCuff", Content = "Must be on Police / Sheriff!", Duration = 3 })
            return
        end
        weldAllNearby()
    elseif input.KeyCode == cfg.arrestKeybind then
        arrestAll()
    end
end)

