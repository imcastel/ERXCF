local countdownActive = false
local Settings = RS:FindFirstChild("PrivateServers")

-- Server Hop Function
local function ServerHop()
    if hopInProgress then return end
    hopInProgress = true

    local TeleportService = game:GetService("TeleportService")
    local HttpService = game:GetService("HttpService")
    local PlaceId = game.PlaceId
    
    WindUI:Notify({ Title = "Server Hop", Content = "Looking for populated server...", Duration = 3 })
    
    pcall(function()
        local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        local validServers = {}
        
        for _, v in ipairs(servers.data) do
            if v.playing >= cfg.minServerPlayers and v.id ~= game.JobId then
                table.insert(validServers, v)
            end
        end
        
        if #validServers > 0 then
            local target = validServers[math.random(1, #validServers)]
            WindUI:Notify({ Title = "Server Hop", Content = "Hopping... (" .. target.playing .. " players)", Duration = 4 })
            TeleportService:TeleportToPlaceInstance(PlaceId, target.id)
        else
            WindUI:Notify({ Title = "Server Hop", Content = "No big servers found. Retrying...", Duration = 5 })
            task.wait(6)
            hopInProgress = false
            ServerHop()
        end
    end)
    
    task.delay(30, function() hopInProgress = false end)
end

local function isPoliceTeam(p)
    local t = p.Team
    return t and (t.Name == "Police" or t.Name == "Sheriff")
end

local function isWanted(p)
    if not p or not p.Team then return false end
    if p.Team.Name == "Jail" then return false end
    if p:FindFirstChild("Is_Wanted") then return true end
    if Settings and Settings:FindFirstChild("ArrestCivs") and Settings.ArrestCivs.Value then
        return p.Team.Name == "Civilian"
    end
    return false
end

local function isDead(p)
    local char = p.Character
    local hum = char and char:FindFirstChildWhichIsA("Humanoid")
    return not hum or hum.Health <= 0
end

local function distanceTo(p)
    local myHRP = getHRP()
    local tHRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP or not tHRP then return math.huge end
    return (myHRP.Position - tHRP.Position).Magnitude
end

local function isValidTarget(p)
    if p == LocalPlayer then return false end
    if isPoliceTeam(p) then return false end
    if cuffedPlayers[p] then return false end
    if isDead(p) then return false end
    if not isWanted(p) then return false end
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

local function hasAnyWanted()
    for _, p in ipairs(Players:GetPlayers()) do
        if isValidTarget(p) then
            return true
        end
    end
    return false
end

local function getHandcuffs()
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
    local char = getChar()
    return (bp and bp:FindFirstChild("Handcuffs")) or (char and char:FindFirstChild("Handcuffs"))
end

local function ensureHandcuffsEquipped()
    local hc = getHandcuffs()
    local hum = getHuman()
    if not hc or not hum then return false end
    if not getChar():FindFirstChild("Handcuffs") then
        hum:EquipTool(hc)
        task.wait(0.1)
        pcall(function() EquippedHC:FireServer(true) end)
    end
    return true
end

local pendingAttached = {}

local function flushAttachNotification()
    if notifyPending then return end
    notifyPending = true
    task.delay(0.5, function()
        if #pendingAttached > 0 then
            local names = table.concat(pendingAttached, ", ")
            WindUI:Notify({ Title = "MultiCuff", Content = "⛓ Attached: " .. names, Duration = 3 })
            table.clear(pendingAttached)
        end
        notifyPending = false
    end)
end

-- Fast & Clean Eject + Cuff (using ERX owner's logic)
local function weldPlayer(target)
    if not isValidTarget(target) then return false, "Invalid target" end
    if not ensureHandcuffsEquipped() then return false, "No handcuffs" end
    
    local myChar = getChar()
    if not myChar then return false, "No character" end
    
    -- Clear your velocity to reduce sticking
    local myHRP = getHRP()
    if myHRP then
        myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        myHRP.Velocity = Vector3.new(0, 0, 0)
    end
    
    local tHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if tHRP then
        myChar:PivotTo(CFrame.new(tHRP.Position + Vector3.new(3.5, 2.5, 0)))
    end
    
    -- Minimal delay before cuff
    task.wait(0.08)
    
    for i = 1, cfg.maxAttempts do
        ensureHandcuffsEquipped()
        if isDead(target) then return false, "Target died" end
        
        -- Clean fast cuff (game auto-unsits)
        local Response = UseHandcuffs:InvokeServer("Handcuff", target)
        
        if Response == "Success" then
            cuffedPlayers[target] = true
            table.insert(pendingAttached, target.Name)
            flushAttachNotification()
            
            if cfg.autoArrest then
                task.wait(0.15)
                pcall(function() UseHandcuffs:InvokeServer("Arrest", target) end)
            end
            
            return true, "Success"
        end
        
        task.wait(cfg.retryDelay)
    end
    return false, "Max attempts reached"
end

local function arrestAll()
    local count = 0
    for target in pairs(cuffedPlayers) do
        pcall(function() UseHandcuffs:InvokeServer("Arrest", target) end)
        cuffedPlayers[target] = nil
        count += 1
    end
    WindUI:Notify({
        Title = "MultiCuff",
        Content = count > 0 and "Arrested " .. count .. " player(s)." or "Nobody attached.",
        Duration = 3,
    })
end

local function weldAllNearby()
    if activeCuffThread then
        task.cancel(activeCuffThread)
        activeCuffThread = nil
    end
    
    activeCuffThread = task.spawn(function()
        local targets = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if isValidTarget(p) and distanceTo(p) <= (tonumber(cfg.auraRange) or 35) then
                table.insert(targets, p)
            end
        end
        
        if #targets == 0 then
            WindUI:Notify({ Title = "MultiCuff", Content = "No valid targets nearby.", Duration = 3 })
            return
        end
        
        local threads = {}
        for _, target in ipairs(targets) do
            threads[#threads + 1] = task.spawn(function()
                local ok, msg = weldPlayer(target)
                if not ok then warn("[MultiCuff] Failed: " .. target.Name .. " — " .. msg) end
            end)
        end
        
        for _, t in ipairs(threads) do
            repeat task.wait() until coroutine.status(t) == "dead"
        end
        activeCuffThread = nil
    end)
end

local function startAutoWeld()
    if autoCuffConn then return end
    autoCuffConn = RunService.Heartbeat:Connect(function()
        if not cfg.autoCuffLoop then return end
        
        if cfg.autoServerHop and not hopInProgress and not countdownActive then
            local now = tick()
            if now - lastHopCheck > 15 then
                lastHopCheck = now
                
                if not hasAnyWanted() then
                    countdownActive = true
                    
                    task.spawn(function()
                        for i = 3, 1, -1 do
                            WindUI:Notify({ Title = "Server Hop", Content = "No wanted players. Hopping in " .. i .. "...", Duration = 1.2 })
                            task.wait(1)
                            if hasAnyWanted() then
                                WindUI:Notify({ Title = "Server Hop", Content = "Wanted player appeared. Cancelled.", Duration = 3 })
                                countdownActive = false
                                return
                            end
                        end
                        
                        if not hasAnyWanted() then
                            ServerHop()
                        else
                            WindUI:Notify({ Title = "Server Hop", Content = "Wanted player appeared. Cancelled.", Duration = 3 })
                        end
                        countdownActive = false
                    end)
                end
            end
        end
        
        for _, p in ipairs(Players:GetPlayers()) do
            if isValidTarget(p) and distanceTo(p) <= (tonumber(cfg.auraRange) or 35) then
                task.spawn(weldPlayer, p)
            end
        end
    end)
end

local function stopAutoWeld()
    if autoCuffConn then 
        autoCuffConn:Disconnect() 
        autoCuffConn = nil 
    end
end

