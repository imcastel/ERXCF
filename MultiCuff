-- ───────────────────────────────────────────────────
-- Config save / load
-- ───────────────────────────────────────────────────
local CONFIG_PATH = "ERX/MultiCuff_config.json"

local function saveConfig()
    pcall(function() if not isfolder("ERX") then makefolder("ERX") end end)
    local data = {
        auraRange          = cfg.auraRange,
        retryDelay         = math.floor(cfg.retryDelay * 1000),
        autoCuffLoop       = cfg.autoCuffLoop,
        autoArrest         = cfg.autoArrest,
        autoServerHop      = cfg.autoServerHop,
        minServerPlayers   = cfg.minServerPlayers,
        autoDisableOnDeath = cfg.autoDisableOnDeath,
        ignoreEnabled      = cfg.ignoreEnabled,
        auraVisualizer     = cfg.auraVisualizer,
        playerHighlight    = cfg.playerHighlight,
        webhookEnabled     = cfg.webhookEnabled,
        webhookURL         = cfg.webhookURL,
    }
    local ok = pcall(writefile, CONFIG_PATH, HttpService:JSONEncode(data))
    notify(ok and "Config saved!" or "Failed to save config.")
end

local function loadConfig()
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not ok or not raw or raw == "" then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or type(data) ~= "table" then return end
    if type(data.auraRange)          == "number"  then cfg.auraRange          = data.auraRange end
    if type(data.retryDelay)         == "number"  then cfg.retryDelay         = data.retryDelay / 1000 end
    if type(data.autoCuffLoop)       == "boolean" then cfg.autoCuffLoop       = data.autoCuffLoop end
    if type(data.autoArrest)         == "boolean" then cfg.autoArrest         = data.autoArrest end
    if type(data.autoServerHop)      == "boolean" then cfg.autoServerHop      = data.autoServerHop end
    if type(data.minServerPlayers)   == "number"  then cfg.minServerPlayers   = data.minServerPlayers end
    if type(data.autoDisableOnDeath) == "boolean" then cfg.autoDisableOnDeath = data.autoDisableOnDeath end
    if type(data.ignoreEnabled)      == "boolean" then cfg.ignoreEnabled      = data.ignoreEnabled end
    if type(data.auraVisualizer)     == "boolean" then cfg.auraVisualizer     = data.auraVisualizer end
    if type(data.playerHighlight)    == "boolean" then cfg.playerHighlight    = data.playerHighlight end
    if type(data.webhookEnabled)     == "boolean" then cfg.webhookEnabled     = data.webhookEnabled end
    if type(data.webhookURL)         == "string"  then cfg.webhookURL         = data.webhookURL end
end

loadConfig()

