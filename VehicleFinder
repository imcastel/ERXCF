if _G.ERX_VehicleFinder then
    WindUI:Notify({Title = "Vehicle Finder", Content = "Already loaded!", Duration = 3})
    return
end
_G.ERX_VehicleFinder = true

local WindUI = _G.WindUI
local Window = _G.Window
local ConfigManager = Window.ConfigManager

local Highlight = Instance.new("Highlight")
Highlight.FillTransparency = 0.7
Highlight.OutlineTransparency = 0
Highlight.OutlineColor = Color3.fromRGB(0, 255, 255)
Highlight.FillColor = Color3.fromRGB(0, 255, 255)

local currentHighlight = nil

local function FindMyVehicle()
    if currentHighlight and currentHighlight.Parent then
        currentHighlight:Destroy()
        currentHighlight = nil
    end

    for _, vehicle in ipairs(workspace:FindFirstChild("Vehicles") and workspace.Vehicles:GetChildren() or {}) do
        if vehicle:GetAttribute("Owner") == game.Players.LocalPlayer.Name or 
           (vehicle:FindFirstChild("Seat") and vehicle.Seat:FindFirstChild("Player") and vehicle.Seat.Player.Value == game.Players.LocalPlayer) then
            
            currentHighlight = Highlight:Clone()
            currentHighlight.Adornee = vehicle
            currentHighlight.Parent = vehicle
            
            WindUI:Notify({
                Title = "Vehicle Finder",
                Content = "Your vehicle has been found!",
                Duration = 5
            })
            return
        end
    end

    WindUI:Notify({
        Title = "Vehicle Finder",
        Content = "No owned vehicle found in the server.",
        Duration = 4
    })
end

local tab = Window:Tab({Title = "Vehicle Finder", Icon = "search"})

tab:Section({Title = "Car Finder"})
tab:Button({
    Title = "Find My Vehicle",
    Desc = "It's like Apple Find My, but.... for your ERLC vehicle",
    Callback = FindMyVehicle
})

tab:Button({
    Title = "Get lost!",
    Desc = "Make it impossible to find your car again. (Removes the highlight from your vehicle)",
    Callback = function()
        if currentHighlight and currentHighlight.Parent then
            currentHighlight:Destroy()
            currentHighlight = nil
        end
        WindUI:Notify({Title = "Vehicle Finder", Content = "Car GONE! Good luck finding it now..", Duration = 3})
    end
})

local FinderConfig = ConfigManager:CreateConfig("ERX_VehicleFinder")
FinderConfig:Load()
tab:Section({ Title = "Credits" })
tab:Paragraph({
    Title = "Vehicle Finder for ERX",
    Desc  = "Made by castel0v2",
})
WindUI:Notify({
    Title = "Vehicle Finder",
    Content = "Loaded successfully! Click the button to find your car.",
    Duration = 6
})
